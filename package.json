{
  "name": "ai-agent",
  "version": "1.0.0",
  "description": "AI Bug Recording Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron . --no-sandbox",
    "start": "npm run build && electron . --no-sandbox",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox --dev\""
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "vue": "^3.4.0",
    "markdown-it": "^14.0.0",
    "dompurify": "^3.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ai-agent.app",
    "productName": "AI Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "web/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "web/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "web/icon.icns"
    }
  }
}
